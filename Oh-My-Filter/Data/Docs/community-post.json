  "/posts/geolocation": {
    "get": {
      "tags": [
        "Community-Post"
      ],
      "summary": "(위치 기반)게시글 조회",
      "description": "[Point]\n<br>위치기반 게시물 조회 커뮤니티를 운영하는 경우에는, 요청쿼리에 위경도 값과 적절한 maxDistance를 포함하여 요청해 주세요.\\\n<br>위치기반이 아닌, 단순 게시물 조회 커뮤니티를 운영하는 경우에는, 요청쿼리에 위경도 값과 maxDistance를 포함하지 말아 주세요.\\\n<br><br>\n[요청 쿼리]<br>\n   \\- 입력하지 않을 시 기본값\\\n<br> 1. category: 전체 게시글을 조회\\\n<br> 2. longitude: 청취사 경도값\\\n<br> 3. latitude: 청취사 위도값\\\n<br> 4. maxDistance: 전체 반경을 조회\\\n<br> 5. limit: 한 페이지당 보여지는 게시글 개수 (기본값: 5)\\\n<br> 6. next: 다음 페이지 조회를 위한 커서값 (처음 요청시 빈 값, 이후 응답의 next_cursor 값 사용)\\\n<br><br>\n [응답값]\n <br> 1. next_cursor: 다음 페이지 조회를 위한 커서값 (\"0\"인 경우 마지막 페이지)",
      "operationId": "setSwitchTimer",
      "parameters": [
        {
          "name": "category",
          "in": "query",
          "description": "카테고리",
          "required": false,
          "style": "form",
          "explode": true,
          "schema": {
            "type": "string",
            "example": "핫스팟"
          }
        },
        {
          "name": "longitude",
          "in": "query",
          "description": "경도",
          "required": false,
          "style": "form",
          "explode": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "latitude",
          "in": "query",
          "description": "위도",
          "required": false,
          "style": "form",
          "explode": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "maxDistance",
          "in": "query",
          "description": "반경(미터 단위)",
          "required": false,
          "style": "form",
          "explode": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "limit",
          "in": "query",
          "description": "한 페이지당 보여지는 게시글 개수 (기본값: 5)",
          "required": false,
          "style": "form",
          "explode": true,
          "schema": {
            "type": "integer",
            "default": 5
          }
        },
        {
          "name": "next",
          "in": "query",
          "description": "다음 페이지 조회를 위한 post_id",
          "required": false,
          "style": "form",
          "explode": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "order_by",
          "in": "query",
          "description": "정렬 기준 (createdAt: 최신순, likes: 좋아요 많은 순)",
          "required": false,
          "style": "form",
          "explode": true,
          "schema": {
            "type": "string",
            "enum": [
              "createdAt",
              "likes"
            ],
            "default": "createdAt"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "response",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostSummaryPaginationResponseDTO"
              }
            }
          }
        },
        "400": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "default": "유효하지 않은 값 타입입니다."
                  }
                },
                "required": [
                  "message"
                ]
              }
            }
          }
        }
      },
      "security": [
        {
          "Authorization": []
        },
        {
          "SeSACKey": []
        }
      ]
    }
  },
