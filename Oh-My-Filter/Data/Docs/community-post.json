                  "value": {
                    "message": "필수값을 채워주세요."
                  }
                },
                "유효하지 않은 값 타입": {
                  "value": {
                    "message": "유효하지 않은 값 타입입니다."
                  }
                },
                "사용할 수 없는 카테고리 명": {
                  "value": {
                    "message": "사용할 수 없는 카테고리 명입니다."
                  }
                }
              }
            }
          }
