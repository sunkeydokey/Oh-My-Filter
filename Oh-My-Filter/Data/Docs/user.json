  "/users/join": {
    "post": {
      "tags": [
        "User"
      ],
      "summary": "회원가입",
      "description": "[회원가입 규칙]\n<br>1. email은 중복 체크됩니다.\n<br>2. - . , ? * - @ + ^ $ { } ( ) | [ ] \\는 nick에 포함할 수 없습니다.\n<br>3. 이메일은 유효한 형식이어야 합니다 (예: user@example.com)\n<br>4. 비밀번호는 최소 8자 이상이며, 영문자, 숫자, 특수문자(@$!%*#?&)를 각각 1개 이상 포함해야 합니다.",
      "operationId": "get-v1-users-join",
      "parameters": [],
      "requestBody": {
        "$ref": "#/components/requestBodies/JoinRequestDTO"
      },
      "responses": {
        "200": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinResponseDTO"
              }
            }
          }
        },
        "400": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Error"
              },
              "examples": {
                "필수값이 없는 경우": {
                  "value": {
                    "message": "필수값을 채워주세요."
                  }
                },
                "이메일 형식이 올바르지 않은 경우": {
                  "value": {
                    "message": "이메일 형식이 올바르지 않습니다."
                  }
                },
                "비밀번호 형식이 올바르지 않은 경우": {
                  "value": {
                    "message": "비밀번호는 최소 8자 이상이며, 영문자, 숫자, 특수문자를 포함해야 합니다."
                  }
                },
                "사용할 수 없는 닉네임인 경우": {
                  "value": {
                    "message": "사용할 수 없는 닉네임입니다."
                  }
                }
              }
            }
          }
        },
        "409": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "default": "이미 가입된 유저입니다."
                  }
                },
                "required": [
                  "message"
                ]
              }
            }
          }
        }
      },
      "security": [
        {
          "SeSACKey": []
        }
      ]
    }
  },
