{
  "/common": {
    "get": {
      "tags": [
        "공통적용 사항"
      ],
      "summary": "공통사항 정의",
      "description": "서비스의 모든 요청 header에는 **SeSACKey**를 넣어주어야 합니다.  \n자물쇠 모양을 클릭하면 해당 기능에 필요한 AccessToken(Authorization)과 SeSACKey를 설정할 수 있습니다.  \n<br>\nstatusCode가 같은 응답값이 2개 이상 존재할 경우 Response의 Examples에 드롭다운 형태로 표시됩니다.  \n<br>\n 업로드한 파일을 조회 시 header에 **AccessToken(Authorization), SeSACKey**를 입력해야 합니다.\n<br>\n url 예) http://filter.sesac.kr:99999/data/profiles/1712740785422.png",
      "operationId": "get-api-v1-common",
      "responses": {
        "200": {
          "description": ""
        },
        "401": {
          "description": "유효하지 않은 accessToken일 경우(공백 포함, 한글 포함 등)",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "default": "인증할 수 없는 액세스 토큰입니다."
                  }
                },
                "required": [
                  "message"
                ]
              }
            }
          }
        },
        "403": {
          "description": "user_id 조회를 할 수 없는 경우(공백, 탈퇴한 회원 등)",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "default": "Forbidden"
                  }
                },
                "required": [
                  "message"
                ]
              }
            }
          }
        },
        "419": {
          "description": "accessToken이 만료된 경우",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "default": "액세스 토큰이 만료되었습니다."
                  }
                },
                "required": [
                  "message"
                ]
              }
            }
          }
        },
        "420": {
          "description": "header의 SeSACKey가 유효하지 않는 경우",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "default": "This service sesac_memolease only"
                  }
                },
                "required": [
                  "message"
                ]
              }
            }
          }
        },
        "429": {
          "description": "정해진 api 호출 횟수를 초과한 경우",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "default": "과호출입니다."
                  }
                },
                "required": [
                  "message"
                ]
              }
            }
          }
        },
        "444": {
          "description": "비정상 api 호출인 경우 (잘못된 url 등)",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "default": "돌아가 여긴 자네가 올 곳이 아니야."
                  }
                },
                "required": [
                  "message"
                ]
              }
            }
          }
        },
        "500": {
          "description": "이외 서버관련 Error",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "default": "ServerError"
                  }
                },
                "required": [
                  "message"
                ]
              }
            }
          }
        }
      },
      "security": [
        {
          "SeSACKey": []
        }
      ]
    }
  },
